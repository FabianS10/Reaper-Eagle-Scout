APP_ENV=development
DATABASE_URL=sqlite:///./eagle_scout.db

# Bright Data — required for live web intelligence
BRIGHTDATA_API_KEY=2d72cbde-fe93-4e20-9200-3e2abfdf3b9a
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1

